# Copy this file to `.env` and fill in your key. NEVER commit the real .env.
#   cp .env.sample .env

# Required: your Gemini API key (free at https://aistudio.google.com/apikey).
# GOOGLE_API_KEY or API_KEY are also accepted.
GEMINI_API_KEY=your-gemini-api-key-here

# --- Optional overrides (defaults shown) -----------------------------------
# STORE_DISPLAY_NAME=OptiBot Support Docs
# EMBEDDING_MODEL=models/gemini-embedding-001
# CHUNK_MAX_TOKENS=512        # Gemini max is 512 tokens/chunk
# CHUNK_OVERLAP_TOKENS=100
# ARTICLES_DIR=articles
# MAX_ARTICLES=            # leave empty for all; set e.g. 40 for a quick test
